# Normalize line endings to LF on checkin.
* text=auto eol=lf

# Explicitly treat known text types as text.
*.ts text
*.js text
*.json text
*.md text
*.yml text
*.yaml text

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Mark generated output so diffs/linguist treat it as such.
dist/** linguist-generated=true
package-lock.json linguist-generated=true
